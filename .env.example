# --- PROJECT SETTINGS ---
# Set to True for development, False for production
DEBUG=True
# Generate a fresh secret key for your local setup
SECRET_KEY=your-secret-key-here

# --- DATABASE SETTINGS ---
# Format: postgis://user:password@localhost:5432/dbname
# Remember: Use 'postgis://' for GeoDjango, not 'postgres://'
DATABASE_URL=postgis://username:password@localhost:5432/database_name

# --- ALLOWED HOSTS ---
# Comma-separated list (e.g., localhost,127.0.0.1)
ALLOWED_HOSTS=localhost,127.0.0.1